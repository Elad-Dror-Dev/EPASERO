# Contact form delivery (spec §8.3) — https://resend.com
# CONTACT_FROM must be a verified sender on a domain you own.
RESEND_API_KEY=
CONTACT_FROM=website@epaserocontracting.com

# Google Reviews for the Client Stories section (spec §4.7).
# Create the key in Google Cloud with the "Places API (New)" enabled, and
# restrict it to your server. NEVER prefix these with NEXT_PUBLIC_ — that would
# ship the key to the browser and let anyone bill your account.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
